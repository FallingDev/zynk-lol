generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  password      String?
  username      String    @unique
  emailverified DateTime?
  
  discordid       String? @unique @map("discordid")
  discordusername String? @map("discordusername")
  avatar          String?
  
  role        String    @default("user")
  ispremium   Boolean   @default(false) @map("ispremium")
  premiumsince DateTime? @map("premiumsince")
  
  createdat DateTime @default(now()) @map("createdat")
  updatedat DateTime @updatedAt @map("updatedat")
  
  profile     Profile?
  links       Link[]
  badges      UserBadge[]
  widgets     Widget[]
  tracks      Track[]
  templates   Template[]
  views       ProfileView[]
  payments    Payment[]
  accounts    Account[]
  sessions    Session[]
  
  @@map("users")
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique @map("userid")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  displayName String? @map("displayname")
  bio         String? @db.Text @map("bio")
  location    String? @map("location")
  occupation  String? @map("occupation")
  tags        String[] @map("tags")
  
  accentColor  String   @default("#8b5cf6") @map("accentcolor")
  font         String   @default("Inter") @map("font")
  borderRadius String   @default("16px") @map("borderradius")
  effects      Json     @default("{}") @map("effects")
  layout       String   @default("floating") @map("layout")
  avatarShape  String   @default("circle") @map("avatarshape")
  
  bannerUrl String? @map("bannerurl")
  
  pageTitle       String? @map("pagetitle")
  ogImage         String? @map("ogimage")
  commentsEnabled Boolean @default(true) @map("commentsenabled")
  
  backgroundType  String  @default("solid") @map("backgroundtype")
  backgroundValue String  @default("#0a0a0a") @map("backgroundvalue")
  
  cardStyle String @default("glass") @map("cardstyle")
  
  glowEnabled Boolean @default(false) @map("glowenabled")
  tiltEnabled Boolean @default(false) @map("tiltenabled")
  animationEnabled Boolean @default(true) @map("animationenabled")
  
  createdAt DateTime @default(now()) @map("createdat")
  updatedAt DateTime @updatedAt @map("updatedat")
  
  @@map("profiles")
}

model Link {
  id        String   @id @default(cuid())
  profileId String   @map("profileid")
  userId    String   @map("userid")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title String
  url   String
  icon  String?
  order Int     @default(0) @map("order")
  style String  @default("filled") @map("style")
  
  createdAt DateTime @default(now()) @map("createdat")
  updatedAt DateTime @updatedAt @map("updatedat")
  
  @@index([userId])
  @@map("links")
}

model Badge {
  id          String @id @default(cuid())
  name        String @unique
  description String
  icon        String
  type        String @default("earned") @map("type")
  
  users UserBadge[]
  
  @@map("badges")
}

model UserBadge {
  id     String @id @default(cuid())
  userId String @map("userid")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId String @map("badgeid")
  badge   Badge  @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  
  earnedAt DateTime @default(now()) @map("earnedat")
  
  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Template {
  id          String @id @default(cuid())
  name        String
  description String @db.Text
  previewImage String @map("previewimage")
  tags        String[]
  
  creatorId String @map("creatorid")
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  status      String  @default("pending") @map("status")
  usageCount  Int     @default(0) @map("usagecount")
  isPremium   Boolean @default(false) @map("ispremium")
  
  config Json @default("{}")
  
  createdAt DateTime @default(now()) @map("createdat")
  updatedAt DateTime @updatedAt @map("updatedat")
  
  @@index([status])
  @@map("templates")
}

model Widget {
  id        String @id @default(cuid())
  userId    String @map("userid")
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type    String
  config  Json    @default("{}")
  enabled Boolean @default(true) @map("enabled")
  order   Int     @default(0) @map("order")
  
  @@index([userId])
  @@map("widgets")
}

model Track {
  id     String @id @default(cuid())
  userId String @map("userid")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title    String
  embedUrl String? @map("embedurl")
  style    String @default("compact") @map("style")
  order    Int    @default(0) @map("order")
  
  @@index([userId])
  @@map("tracks")
}

model ProfileView {
  id        String   @id @default(cuid())
  userId    String   @map("userid")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  viewedAt DateTime @default(now()) @map("viewedat")
  ipHash   String? @map("iphash")
  
  @@index([userId])
  @@index([viewedAt])
  @@map("profile_views")
}

model Payment {
  id     String @id @default(cuid())
  userId String @map("userid")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("USD") @map("currency")
  status   String  @default("pending") @map("status")
  
  stripePaymentIntentId String? @map("stripepaymentintentid")
  
  createdAt DateTime @default(now()) @map("createdat")
  updatedAt DateTime @updatedAt @map("updatedat")
  
  @@map("payments")
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("userid")
  type              String
  provider          String
  providerAccountId String  @map("provideraccountid")
  refresh_token     String? @map("refresh_token")
  access_token      String? @map("access_token")
  expires_at        Int?    @map("expires_at")
  token_type        String? @map("token_type")
  scope             String?
  id_token          String? @map("id_token")
  session_state     String? @map("session_state")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("sessiontoken")
  userId       String   @map("userid")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
