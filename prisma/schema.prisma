generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  username      String    @unique
  emailVerified DateTime? @map("emailverified")
  
  discordId       String? @unique @map("discordid")
  discordUsername String? @map("discordusername")
  avatar          String?
  
  role        String    @default("user") @map("role")
  isPremium   Boolean   @default(false) @map("ispremium")
  premiumSince DateTime? @map("premiumsince")
  
  createdAt DateTime @default(now()) @map("createdat")
  updatedAt DateTime @updatedAt @map("updatedat")
  
  profile     Profile?
  links       Link[]
  badges      UserBadge[]
  widgets     Widget[]
  tracks      Track[]
  templates   Template[]
  views       ProfileView[]
  payments    Payment[]
  
  @@map("users")
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  displayName String?
  bio         String? @db.Text
  location    String?
  occupation  String?
  tags        String[]
  
  accentColor  String   @default("#8b5cf6")
  font         String   @default("Inter")
  borderRadius String   @default("16px")
  effects      Json     @default("{}")
  layout       String   @default("floating")
  avatarShape  String   @default("circle")
  
  bannerUrl String?
  
  pageTitle       String?
  ogImage         String?
  commentsEnabled Boolean @default(true)
  
  backgroundType  String  @default("solid")
  backgroundValue String  @default("#0a0a0a")
  
  cardStyle String @default("glass")
  
  glowEnabled Boolean @default(false)
  tiltEnabled Boolean @default(false)
  animationEnabled Boolean @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("profiles")
}

model Link {
  id        String   @id @default(cuid())
  profileId String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title String
  url   String
  icon  String?
  order Int     @default(0)
  style String  @default("filled")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([userId])
  @@map("links")
}

model Badge {
  id          String @id @default(cuid())
  name        String @unique
  description String
  icon        String
  type        String @default("earned")
  
  users UserBadge[]
  
  @@map("badges")
}

model UserBadge {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId String
  badge   Badge  @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  
  earnedAt DateTime @default(now())
  
  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Template {
  id          String @id @default(cuid())
  name        String
  description String @db.Text
  previewImage String
  tags        String[]
  
  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  status      String  @default("pending")
  usageCount  Int     @default(0)
  isPremium   Boolean @default(false)
  
  config Json @default("{}")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([status])
  @@map("templates")
}

model Widget {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type    String
  config  Json    @default("{}")
  enabled Boolean @default(true)
  order   Int     @default(0)
  
  @@index([userId])
  @@map("widgets")
}

model Track {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title    String
  embedUrl String?
  style    String @default("compact")
  order    Int    @default(0)
  
  @@index([userId])
  @@map("tracks")
}

model ProfileView {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  viewedAt DateTime @default(now())
  ipHash   String?
  
  @@index([userId])
  @@index([viewedAt])
  @@map("profile_views")
}

model Payment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("USD")
  status   String  @default("pending")
  
  stripePaymentIntentId String?
  
  createdAt DateTime @default(now()) @map("createdat")
  updatedAt DateTime @updatedAt @map("updatedat")
  
  @@map("payments")
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("userid")
  type              String
  provider          String
  providerAccountId String  @map("provideraccountid")
  refresh_token     String? @map("refresh_token")
  access_token      String? @map("access_token")
  expires_at        Int?    @map("expires_at")
  token_type        String? @map("token_type")
  scope             String?
  id_token          String? @map("id_token")
  session_state     String? @map("session_state")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("sessiontoken")
  userId       String   @map("userid")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
